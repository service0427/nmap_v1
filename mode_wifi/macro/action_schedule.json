{
  "config": {
    "polling_interval": 2.0,
    "global_timeout": 900
  },
  "steps": [
    {
      "id": "STEP_02_HOME",
      "desc": "홈 안착 확인 및 검색창 클릭",
      "type": "screenview",
      "screen_name": "home",
      "action": "entry_search_field",
      "category": "01.SearchAndNavi",
      "control": {
        "required": true
      }
    },
    {
      "id": "STEP_03_TYPING",
      "desc": "검색창 진입 및 목적지 입력",
      "type": "screenview",
      "screen_name": "SCH.all.entry",
      "action": "TYPE_DESTINATION",
      "category": "01.SearchAndNavi",
      "control": {
        "required": true
      }
    },
    {
      "id": "STEP_04_SELECT_ADDR",
      "desc": "목록에서 주소 선택",
      "action": "SELECT_ADDR_LIST",
      "category": "01.SearchAndNavi",
      "control": {
        "required": true
      }
    },
    {
      "id": "STEP_05_POI_ARRIVAL",
      "desc": "POI 정보창에서 도착 클릭",
      "type": "action",
      "screen_name": "poi.end",
      "action": "CLICK_ARRIVAL",
      "category": "01.SearchAndNavi",
      "control": {
        "required": true
      }
    },
    {
      "id": "STEP_07_NAVI_START",
      "desc": "경로 탐색 완료(DRT.route.car) 및 안내시작 클릭",
      "type": "action",
      "screen_name": "DRT.route.car",
      "action": "btn_start_guidance",
      "category": "01.SearchAndNavi",
      "control": {
        "required": true
      }
    },
    {
      "id": "STEP_07_1_BUSINESS_MODAL",
      "desc": "영업시간 알림 대응 (필요 시)",
      "type": "screen_start",
      "screen_name": "BusinessHourWarningModalFragment",
      "action": "btn_start_guidance_modal",
      "category": "01.SearchAndNavi",
      "control": {
        "required": false
      }
    },
    {
      "id": "STEP_07_2_DRIVING_STARTED",
      "desc": "실주행 패킷 감지 확인",
      "url": "v3/global/driving",
      "control": {
        "required": true
      }
    },
    {
      "id": "STEP_08_DRIVING_GOAL",
      "desc": "목적지 도착 및 안내종료",
      "url": "v3/global/routeend",
      "action": "exact:안내종료",
      "category": "01.SearchAndNavi",
      "control": {
        "required": true
      }
    },
    {
      "id": "STEP_09_FINISH",
      "desc": "최종 종료 (안내종료 클릭 후 즉시 대기)",
      "action": "EXIT_SUCCESS",
      "control": {
        "required": true
      }
    }
  ]
}